# Copiá este archivo a .env.local y completá los valores.
# .env.local está en .gitignore y no se commitea.

# ── Emulador ────────────────────────────────────────────────────
# IP de tu máquina en la LAN (para dispositivos físicos).
# Dejá vacío o eliminá para auto-detectar (10.0.2.2 en Android emulator, localhost en iOS/web).
# EXPO_PUBLIC_EMULATOR_HOST=192.168.1.16

# ── Firebase (producción) ───────────────────────────────────────
# En __DEV__ estas son ignoradas porque el SDK conecta directo al emulador.
# Solo son necesarias para builds de producción.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── OBD2 Mock ──────────────────────────────────────────────────
# Habilita el servicio simulado de OBD2 (sin hardware real).
# Útil para desarrollar la UI sin un adaptador ELM327 conectado.
# EXPO_PUBLIC_OBD2_MOCK=true
