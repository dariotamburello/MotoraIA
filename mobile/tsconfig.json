{
  "extends": ["expo/tsconfig.base", "../tsconfig.base.json"],
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@motora/types": ["../packages/types/src/index.ts"],
      "@motora/types/*": ["../packages/types/src/*"],
      "@motora/design-tokens": ["../packages/design-tokens/src/index.ts"],
      "@motora/design-tokens/*": ["../packages/design-tokens/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"]
}
