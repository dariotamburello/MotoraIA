# Expo + React Native sobre pnpm en Windows: el path nested .pnpm/<pkg>@<ver>_<hash>
# rompe CMake (límite 250 chars para object files) y Metro/Gradle no resuelven
# bien los symlinks. Hoisted node_modules es el modo recomendado por Expo para
# monorepos pnpm — preserva workspaces pero usa layout flat estilo npm.
node-linker=hoisted

# Auto-aprobar build scripts que Expo necesita (esbuild, expo-modules, biome, etc.)
# para no requerir `pnpm approve-builds` interactivo en CI.
auto-install-peers=true
strict-peer-dependencies=false
